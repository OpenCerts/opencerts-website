SENTRY_AUTH_TOKEN=your_sentry_auth_token_here
# On GitHub Actions: set SENTRY_UPLOAD_SOURCE_MAPS=true only when the token is valid (see deploy workflows).
# SENTRY_UPLOAD_SOURCE_MAPS=true
# Same project DSN for server/edge; client uses NEXT_PUBLIC_SENTRY_DSN (often set to the same value).
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Build-time tags for static export (deploy workflows set these explicitly as NEXT_PUBLIC_*).
NEXT_PUBLIC_SENTRY_ENVIRONMENT=development
NEXT_PUBLIC_SENTRY_RELEASE=local-dev
NODE_ENV=development # or production
